<Window x:Class="CYBER_WATCH_AI_POE_PART_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CYBER_WATCH_AI_POE_PART_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <!--start of main parent grid-->

        <!--grid for the username page-->


        <Grid x:Name="name_grid"
      Visibility="Hidden" 
              RenderTransformOrigin="0.498,0.425" 
              Background="Black" 
              
      >


            <!--logo grid-->

            <Image HorizontalAlignment="Left"
                   Width="254"
                   Margin="280,59,0,230" 
                   Source="/eyelogo2.png" 
                   x:Name="logo"
                   
                   />



            <!--start of username grid-->
            <!--Textbox to enter the username-->
            <TextBox 
          Height="50"
          Width="350"
                BorderThickness="2"
                Text="Enter your username"
                Foreground="Gray"
                FontSize="16"
                FontFamily="Trebuchet MS"
                
          x:Name="user_name" Margin="0,244,225,140" HorizontalAlignment="Right"   
          />
            <!--Button to submit username-->

            <Button
          Margin="303,320,290,65"
          Content="Submit Username"
          Background="Red"
          Foreground="Black"
          Click="submit_name"
          FontFamily="Trebuchet MS"
                FontSize="16"
                FontWeight="Heavy"
          />

        </Grid>
        <!--end of username grid-->
        <!--Grid for the chat page-->

        <Grid  
         x:Name="Chat_Grid"
      Visibility="Visible"
            Background="Black"
      
      >
            <!--start of chat page grid-->
            <!--list view to show chats-->

            <ListView
          Background="Black"
                BorderThickness="2"
                FontFamily="Trebuchet MS"
         Height="350"
         Margin="158,12,141,72"
         x:Name="chats"
          
          />

            <!--the question TextBox-->
            <TextBox
         Height="50"
         Margin="158,367,400,17"
         x:Name="question"
          
          />

            <!-- Button to submit the question -->
            <Button
         Height="50"
         Width="200"
         Margin="459,367,141,17"
         Content="send"
         FontSize="16"
         Click="send"
         Background="red"
          Foreground="Black"
         FontFamily="Trebuchet MS"
          />

        </Grid>
        <!--end of chat page grid-->

    </Grid>
</Window>
