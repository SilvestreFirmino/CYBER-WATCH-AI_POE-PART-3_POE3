<Window x:Class="CYBER_WATCH_AI_POE_PART_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CYBER_WATCH_AI_POE_PART_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <!-- 
            HOME GRID
            This grid serves as the main landing page  of the application.
            It contains a logo for AI , a welcome message to greet users,
            and a navigation button to proceed to the next section.
            Currently hidden by default.
        -->
        <Grid x:Name="home_grid" Visibility="Visible"
              Background="Black">


            <!-- Logo -->

            <Image 
                Source="/eyelogo2.png"
                Margin="0,30,0,0" HorizontalAlignment="Center" Width="300" Height="200" VerticalAlignment="Top"
                Opacity="0.6"
                   />
            <!-- welcome message-->



            <TextBlock
                Text="CYBER WATCHER AI chatbot,"
                Foreground="White"
                FontWeight="Bold"
                Height="38"
                FontFamily="Trebuchet MS"
                TextAlignment="Center"
                Margin="0,230,0,0"
                FontSize="26"
                 HorizontalAlignment="Center" Width="518" VerticalAlignment="Top"
                />
            <TextBlock
                Text="WELCOME TO"
                
                Height="38"
                FontFamily="Trebuchet MS"
                TextAlignment="Center"
                Margin="0,192,0,0"
                FontSize="18"
                Foreground="White" HorizontalAlignment="Center" Width="518" VerticalAlignment="Top"
                />
            <TextBlock
                Text="click here to continue "
                
                Height="38"
                FontFamily="Trebuchet MS"
                TextAlignment="Center"
                Margin="141,273,0,0"
                FontSize="16"
                Foreground="White" HorizontalAlignment="Left" Width="518" VerticalAlignment="Top"
                />

            <!-- button to continue-->
            <Button 
                Background="DarkRed"
                
                Height="40"
                Width="200"
                Margin="0,311,0,0"
                Content="ENTER"
                FontSize="18"
                Click="proceed"
                Foreground="White"
                FontFamily="Trebuchet MS" HorizontalAlignment="Center" VerticalAlignment="Top"
                />

        </Grid>

        <!-- 
            USERNAME GRID
            This grid is for prompting the user for username.
            It contains a logo for AI, a textbox for users to enter their name,
            and a submit button to save the username.
            Hidden .
        -->
        <Grid x:Name="username_grid" Visibility="Hidden" Background="Black">


            <!-- Logo -->
            <Image 
                Height= "200"
                Width="300"
                Source="/eyelogo2.png"
                Margin="0,10,0,0" HorizontalAlignment="Center" VerticalAlignment="Top"
                Opacity="0.6"
                   />
            <TextBlock
                     Text="CYBER WATCHER AI chatbot"
                     Foreground="White"
                FontWeight="Bold"
                     Height="38"
                     FontFamily="Trebuchet MS"
                     TextAlignment="Center"
                     Margin="0,165,0,0"
                     FontSize="26"
                     HorizontalAlignment="Center" Width="518" VerticalAlignment="Top"
    />
            <!-- Hint message-->
            <TextBlock
                FontWeight="Bold"
                Foreground="White"
                FontSize="14"
                Text="Enter username"
                Height="20"
                Width="270"
                TextAlignment="Justify"
                Margin="0,30,0,0"
                FontFamily="Trebuchet MS"
                />

            <!-- Enter/Prompt username-->
            <TextBox
                Background="Black"
                Foreground="White"
                Height="40"
                Width="270"
                TextAlignment="Center"
                Margin="0,100,0,0"
                FontFamily="Trebuchet MS"
                x:Name="usernames_input"
                />

            <!-- error message-->
            <TextBlock
         Text="please enter username to continue..."
         Height="20"
         Width="270"
         TextAlignment="Justify"
         Margin="0,180,0,0"
         Foreground="Red"
         FontFamily="Trebuchet MS"
         />

            <!-- button to submit name-->
            <Button 
        Height="40"
        Width="270"
        Margin="0,250,0,0"
        Content="CONFIRM USERNAME"
        Click="submit_name"
                Background="DarkRed"
                Foreground="White"
                FontFamily="Trebuchet MS"
        />

        </Grid>

        <!-- 
            CHAT GRID
            This grid handles all messaging and conversation-related features of the application.
            It contains a ListView to display chat messages, a textbox for typing questions,
            and a submit button to send the question to the chat.
            Starting in a hidden state.
        -->
        <Grid x:Name="chat_grid" Visibility="Hidden" Background="Black">


            <!-- List view to show messages show messages-->
            <ListView  
                Background="Black"
                x:Name="chats" 
                Height="300"
                Margin="0,0,0,120"
                />


            <!-- TextBox to prompt questions-->
            <TextBox
                Background="Black"
                Foreground="White"
                FontFamily="Trebuchet MS"
                x:Name="question"
                Height="50"
                Width="480"
                Margin="0,300,300,0"
                />

            <!-- button to submit -->
            <Button
                Height="50"
                Width="280"
                Margin="490,300,0,0"
                Content="SUBMIT  "
                Click="send"
                Background="DarkRed"
                Foreground="White"
                />

        </Grid>

    </Grid>
</Window>